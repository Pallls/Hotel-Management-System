@model IEnumerable<Booking>

@{
    ViewData["Title"] = "All Bookings";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="display-5 fw-bold">Bookings</h1>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-lg me-2"></i> New Booking
                </a>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Booking ID</th>
                        <th>Guest Name</th>
                        <th>Room</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Total Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td>#@booking.Id</td>
                            <td>@booking.Customer?.Name</td>
                            <td>Room @booking.Room?.RoomNumber</td>
                            <td>@booking.CheckinDate.ToString("MMM dd, yyyy")</td>
                            <td>@booking.CheckoutDate.ToString("MMM dd, yyyy")</td>
                            <td><strong>RM @booking.TotalPrice</strong></td>
                            <td>
                                <span class="badge bg-@GetStatusColor(booking.Status)">@booking.Status</span>
                            </td>
                            <td>
                                <a asp-action="Edit" asp-controller="Booking" asp-route-id="@booking.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@booking.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-calendar-x fs-3 mb-3 d-block"></i>
            <h5>No bookings found</h5>
        </div>
    }
</div>

@functions {
    string GetStatusColor(BookingStatus status)
    {
        return status switch
        {
            BookingStatus.Pending => "warning",
            BookingStatus.Confirmed => "success",
            BookingStatus.CheckedIn => "info",
            BookingStatus.CheckedOut => "dark",
            BookingStatus.Cancelled => "danger",
            _ => "secondary"
        };
    }
}