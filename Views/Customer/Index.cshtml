@model IEnumerable<Customer>

@{
    ViewData["Title"] = "Manage Customers";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 fw-bold">Customer Management</h1>
                    <p class="text-muted">Manage all registered customers</p>
                </div>
                <a asp-action="Create" asp-controller="Customer" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-lg me-2"></i> Add New Customer
                </a>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Address</th>
                        <th>Registered Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in Model)
                    {
                        <tr>
                            <td>#@customer.Id</td>
                            <td>
                                <strong>@customer.Name</strong>
                            </td>
                            <td>@customer.Email</td>
                            <td>@customer.PhoneNumber</td>
                            <td>@customer.Address</td>
                            <td>@customer.RegisteredDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="Edit" asp-controller="Customer" asp-route-id="@customer.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-controller="Customer" asp-route-id="@customer.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-people fs-3 mb-3 d-block"></i>
            <h5>No customers found</h5>
            <p class="mb-0">Click "Add New Customer" to get started</p>
        </div>
    }
</div>