@model IEnumerable<Room>

@{
    ViewData["Title"] = "Manage Rooms";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 fw-bold">Room Management</h1>
                    <p class="text-muted">Manage available rooms and their details</p>
                </div>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-lg me-2"></i> Add New Room
                </a>
            </div>
        </div>
    </div>

    <!-- Rooms Grid -->
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var room in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-bottom position-relative">
                            <h5 class="card-title mb-0">Room @room.RoomNumber</h5>
                            <div class="position-absolute top-0 end-0 mt-2 me-3">
                                @if (room.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Occupied</span>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <p class="mb-2">
                                    <strong class="text-muted">Category:</strong>
                                    <span class="badge bg-info">@room.RoomType</span>
                                </p>
                                <p class="mb-2">
                                    <strong class="text-muted">Price per Night:</strong>
                                    <h6 class="text-primary mb-0">RM @room.PricePerNight</h6>
                                </p>
                                <p class="mb-0">
                                    <strong class="text-muted">Bookings:</strong>
                                    <br />
                                    @room.Bookings.Count() booking(s)
                                </p>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top">
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@room.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-info-circle fs-3 mb-3 d-block"></i>
                    <h5>No rooms found</h5>
                    <p class="mb-0">Click "Add New Room" to get started</p>
                </div>
            </div>
        }
    </div>

    <!-- Room Statistics -->
    <div class="row mt-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <h4 class="text-primary">@Model.Count()</h4>
                    <p class="text-muted mb-0">Total Rooms</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <h4 class="text-success">@Model.Count(r => r.IsAvailable)</h4>
                    <p class="text-muted mb-0">Available</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <h4 class="text-danger">@Model.Count(r => !r.IsAvailable)</h4>
                    <p class="text-muted mb-0">Occupied</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body">
                    <h4 class="text-info">${@Model.Sum(r => r.PricePerNight)}</h4>
                    <p class="text-muted mb-0">Total Revenue/Night</p>
                </div>
            </div>
        </div>
    </div>
</div>