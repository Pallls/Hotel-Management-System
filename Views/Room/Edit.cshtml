@model Room

@{
    ViewData["Title"] = "Edit Room";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">Edit Room @Model.RoomNumber</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="RoomNumber" class="form-label fw-bold">Room Number</label>
                            <input asp-for="RoomNumber" type="text" class="form-control form-control-lg">
                            <span asp-validation-for="RoomNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="RoomType" class="form-label fw-bold">Room Type</label>
                            <select asp-for="RoomType" asp-items="Html.GetEnumSelectList<RoomCategory>()" class="form-select form-select-lg">
                            </select>
                            <span asp-validation-for="RoomType" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PricePerNight" class="form-label fw-bold">Price Per Night</label>
                            <input asp-for="PricePerNight" type="number" step="0.01" class="form-control form-control-lg">
                            <span asp-validation-for="PricePerNight" class="text-danger"></span>
                        </div>


                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-2"></i> Update Room
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left me-2"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}