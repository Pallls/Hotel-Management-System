<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        #sidebar {
            min-width: 260px;
            max-width: 260px;
            background: linear-gradient(135deg, #3f4974 0%, #764ba2 100%);
            color: white;
            transition: all 0.3s;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
            padding: 25px 0 !important;
        }

        #sidebar .sidebar-brand {
            font-size: 1.8rem;
            font-weight: 700;
            padding: 0 20px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        #sidebar .sidebar-brand i {
            font-size: 2rem;
        }

        #sidebar hr {
            border-color: rgba(255, 255, 255, 0.2) !important;
        }

        #sidebar .nav-link {
            color: rgba(255, 255, 255, 0.8);
            padding: 0.75rem 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 3px solid transparent;
            transition: all 0.3s ease;
            margin: 0.25rem 0;
        }

        #sidebar .nav-link i {
            font-size: 1.2rem;
        }

        #sidebar .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.15);
            border-left-color: white;
        }

        #sidebar .nav-link.active {
            color: white;
            background: rgba(255, 255, 255, 0.25);
            border-left-color: white;
            font-weight: 600;
        }

        #sidebar .nav-text {
            font-size: 0.95rem;
        }

        #sidebar .sidebar-menu {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        #content {
            width: 100%;
            overflow-y: auto;
        }

        .navbar-top {
            background: white;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            padding: 1rem 2rem !important;
        }

        .navbar-top .navbar-brand {
            font-weight: 600;
            color: #333;
            font-size: 1.3rem;
        }

        main {
            padding: 2rem;
            min-height: calc(100vh - 80px);
        }

        @@media (max-width: 768px) {
            body { flex-direction: column; }
            #sidebar { min-width: 100%; max-width: 100%; min-height: auto; padding: 1rem !important; }
            #content { width: 100%; }
            main { padding: 1rem; }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <nav id="sidebar" class="d-flex flex-column">
        <div class="sidebar-brand">
            <i class="bi bi-building"></i>
            <span>HotelMS</span>
        </div>
        <hr>
        <ul class="sidebar-menu mb-auto">
            <li>
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2"></i>
                    <span class="nav-text">Dashboard</span>
                </a>
            </li>
            <li>
                <a asp-controller="Booking" asp-action="Index" class="nav-link">
                    <i class="bi bi-calendar-check"></i>
                    <span class="nav-text">Bookings</span>
                </a>
            </li>
            <li>
                <a asp-controller="Room" asp-action="Index" class="nav-link">
                    <i class="bi bi-door-open"></i>
                    <span class="nav-text">Rooms</span>
                </a>
            </li>
            <li>
                <a asp-controller="Customer" asp-action="Index" class ="nav-link">
                    <i class="bi bi-person"></i>
                    <span class="nav-text"> Customers</span>
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <div id="content" class="d-flex flex-column">
        <nav class="navbar-top">
            <div class="d-flex justify-content-between align-items-center">
                <span class="navbar-brand">
                    <i class="bi bi-houses me-2"></i>Hotel Management System
                </span>
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-bell"></i>
                    </button>
                </div>
            </div>
        </nav>

        <main>
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>